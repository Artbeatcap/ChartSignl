# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key

# Polygon.io Configuration (for market data)
# Get your free API key at https://polygon.io/
POLYGON_API_KEY=your-polygon-api-key

# n8n (docker compose): stable JWT for user management — production: openssl rand -hex 32 (never commit real values)
N8N_USER_MANAGEMENT_JWT_SECRET=change_me

# Server Configuration
PORT=4000
NODE_ENV=development

# CORS - allowed origins (comma separated)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Optional: Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
